# ─────────────────────────────────────────────────────────────
# Z-APP — Variables d'environnement (exemple)
# Copier vers backend/.env et renseigner les vraies valeurs.
# ─────────────────────────────────────────────────────────────

# Base de données — Neon (PostgreSQL + pgvector)
# DATABASE_URL : connexion "pooled" utilisée à l'exécution
# DIRECT_URL   : connexion directe utilisée par les migrations Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST/zapp?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/zapp?sslmode=require"

# Cache / sessions — Upstash (Redis, TLS)
REDIS_URL="rediss://default:PASSWORD@HOST:PORT"

# Auth — secrets JWT (générer des valeurs longues et aléatoires)
JWT_ACCESS_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"

# IA — Anthropic Claude (claude-sonnet-4-6)
ANTHROPIC_API_KEY="sk-ant-..."

# Email — Resend
RESEND_API_KEY="re_..."
FROM_EMAIL="nova@z-app.com"

# Fichiers — Cloudinary
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# App
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"
NODE_ENV="development"
PORT="3001"
